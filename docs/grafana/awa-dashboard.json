{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource with OTLP-scraped awa metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Job Throughput",
      "description": "Jobs completed, failed, retried, and cancelled per second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "completed" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "retried" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "cancelled" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        { "expr": "sum(rate(awa_job_completed_total{awa_job_queue=~\"$queue\"}[$__rate_interval]))", "legendFormat": "completed" },
        { "expr": "sum(rate(awa_job_failed_total{awa_job_queue=~\"$queue\"}[$__rate_interval]))", "legendFormat": "failed" },
        { "expr": "sum(rate(awa_job_retried_total{awa_job_queue=~\"$queue\"}[$__rate_interval]))", "legendFormat": "retried" },
        { "expr": "sum(rate(awa_job_cancelled_total{awa_job_queue=~\"$queue\"}[$__rate_interval]))", "legendFormat": "cancelled" }
      ],
      "datasource": { "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "In-Flight Jobs",
      "description": "Currently executing jobs by queue (summed across all worker instances)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20, "stacking": { "mode": "normal" } }
        }
      },
      "targets": [
        { "expr": "sum by (awa_job_queue) (awa_job_in_flight{awa_job_queue=~\"$queue\"})", "legendFormat": "{{awa_job_queue}}" }
      ],
      "datasource": { "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Job Duration (p50 / p95 / p99)",
      "description": "Job execution time percentiles by queue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0 }
        }
      },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le, awa_job_queue) (rate(awa_job_duration_seconds_bucket{awa_job_queue=~\"$queue\"}[$__rate_interval])))", "legendFormat": "p50 {{awa_job_queue}}" },
        { "expr": "histogram_quantile(0.95, sum by (le, awa_job_queue) (rate(awa_job_duration_seconds_bucket{awa_job_queue=~\"$queue\"}[$__rate_interval])))", "legendFormat": "p95 {{awa_job_queue}}" },
        { "expr": "histogram_quantile(0.99, sum by (le, awa_job_queue) (rate(awa_job_duration_seconds_bucket{awa_job_queue=~\"$queue\"}[$__rate_interval])))", "legendFormat": "p99 {{awa_job_queue}}" }
      ],
      "datasource": { "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Throughput by Kind (top 10)",
      "description": "Completed jobs per second broken down by job kind",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 80, "stacking": { "mode": "normal" } }
        }
      },
      "targets": [
        { "expr": "topk(10, sum by (awa_job_kind) (rate(awa_job_completed_total{awa_job_queue=~\"$queue\"}[$__rate_interval])))", "legendFormat": "{{awa_job_kind}}" }
      ],
      "datasource": { "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Claim Latency",
      "description": "Time to claim a batch of jobs from Postgres (p50/p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0 }
        }
      },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le, awa_job_queue) (rate(awa_dispatch_claim_duration_seconds_bucket{awa_job_queue=~\"$queue\"}[$__rate_interval])))", "legendFormat": "p50 {{awa_job_queue}}" },
        { "expr": "histogram_quantile(0.95, sum by (le, awa_job_queue) (rate(awa_dispatch_claim_duration_seconds_bucket{awa_job_queue=~\"$queue\"}[$__rate_interval])))", "legendFormat": "p95 {{awa_job_queue}}" }
      ],
      "datasource": { "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Claim Batch Size",
      "description": "Average jobs claimed per dispatch poll",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        { "expr": "sum by (awa_job_queue) (rate(awa_dispatch_claim_batch_size_sum{awa_job_queue=~\"$queue\"}[$__rate_interval])) / sum by (awa_job_queue) (rate(awa_dispatch_claim_batch_size_count{awa_job_queue=~\"$queue\"}[$__rate_interval]))", "legendFormat": "avg {{awa_job_queue}}" }
      ],
      "datasource": { "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Maintenance Rescues",
      "description": "Jobs rescued by heartbeat, deadline, or callback timeout",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 80 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "heartbeat" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "deadline" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "callback_timeout" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        { "expr": "sum by (awa_rescue_kind) (rate(awa_maintenance_rescues_total[$__rate_interval]))", "legendFormat": "{{awa_rescue_kind}}" }
      ],
      "datasource": { "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Completion Flush Performance",
      "description": "Batch completion flush duration (p50/p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0 }
        }
      },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(awa_completion_flush_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p50 flush" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(awa_completion_flush_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p95 flush" }
      ],
      "datasource": { "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Promotion Throughput",
      "description": "Scheduled/retryable jobs promoted per second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        { "expr": "sum by (awa_job_state) (rate(awa_maintenance_promote_batch_size_sum[$__rate_interval]))", "legendFormat": "{{awa_job_state}} promoted/s" }
      ],
      "datasource": { "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Jobs Inserted / Waiting External",
      "description": "Job insertion rate and callback-parked jobs",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "inserted" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "waiting_external" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        { "expr": "sum(rate(awa_job_inserted_total[$__rate_interval]))", "legendFormat": "inserted" },
        { "expr": "sum(rate(awa_job_waiting_external_total[$__rate_interval]))", "legendFormat": "waiting_external" }
      ],
      "datasource": { "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Error Rate",
      "description": "Failure rate as percentage of total job completions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "sum(rate(awa_job_failed_total{awa_job_queue=~\"$queue\"}[5m])) / (sum(rate(awa_job_completed_total{awa_job_queue=~\"$queue\"}[5m])) + sum(rate(awa_job_failed_total{awa_job_queue=~\"$queue\"}[5m])) + 1e-10)", "legendFormat": "error rate" }
      ],
      "datasource": { "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Jobs In Flight",
      "description": "Total jobs currently executing across all instances",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "sum(awa_job_in_flight{awa_job_queue=~\"$queue\"})", "legendFormat": "in flight" }
      ],
      "datasource": { "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Throughput",
      "description": "Total jobs completed per second (5m avg)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        { "expr": "sum(rate(awa_job_completed_total{awa_job_queue=~\"$queue\"}[5m]))", "legendFormat": "completed/s" }
      ],
      "datasource": { "uid": "${DS_PROMETHEUS}" }
    },
    {
      "title": "Rescues (5m)",
      "description": "Total jobs rescued in last 5 minutes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "sum(increase(awa_maintenance_rescues_total[5m]))", "legendFormat": "rescues" }
      ],
      "datasource": { "uid": "${DS_PROMETHEUS}" }
    }
  ],
  "schemaVersion": 39,
  "tags": ["awa", "job-queue", "postgres"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "queue",
        "query": "label_values(awa_job_in_flight, awa_job_queue)",
        "refresh": 2,
        "type": "query",
        "datasource": { "uid": "${DS_PROMETHEUS}" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Awa Job Queue",
  "uid": "awa-job-queue",
  "version": 2
}
